{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=app.db"
  },
  "Jwt": {
    "Key": "MyAjaxApiSecretKey_MustBe32CharsOrLonger!!",
    "Issuer": "MyAjaxApi",
    "Audience": "MyAjaxApiUsers",
    "ExpiresInMinutes": "60"
  }
}
